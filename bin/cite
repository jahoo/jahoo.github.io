#!/usr/bin/env bash
#
# cite — format a BibTeX key as an APA citation using pandoc citeproc
#
# Usage:
#   cite KEY BIB_FILE           # full reference (bibliography entry)
#   cite -i KEY BIB_FILE        # inline citation, e.g. "Douc et al. (2005)"
#   cite -p KEY BIB_FILE        # parenthetical, e.g. "(Douc et al., 2005)"
#
# Requires: pandoc (with citeproc), curl.
# Downloads CSL files on first use and caches them in ~/.cache/csl/.

set -euo pipefail

CSL_CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/csl"
CSL_URL="https://raw.githubusercontent.com/citation-style-language/styles/master/apa.csl"
CSL="$CSL_CACHE/apa.csl"

if [[ ! -f "$CSL" ]]; then
    mkdir -p "$CSL_CACHE"
    echo "Downloading apa.csl..." >&2
    curl -fsSL "$CSL_URL" -o "$CSL"
fi

usage() {
    echo "Usage: cite [-i|-p] KEY BIB_FILE" >&2
    echo "  -i  inline citation   (Author, Year)" >&2
    echo "  -p  parenthetical     (Author, Year)" >&2
    echo "  (default: full reference entry)" >&2
    exit 1
}

MODE="ref"
while getopts "ip" opt; do
    case "$opt" in
        i) MODE="inline" ;;
        p) MODE="parens" ;;
        *) usage ;;
    esac
done
shift $((OPTIND - 1))

[[ $# -lt 2 ]] && usage

KEY="$1"
BIB="$2"

if [[ ! -f "$BIB" ]]; then
    echo "Error: bib file not found: $BIB" >&2
    exit 1
fi

case "$MODE" in
    ref)
        # Full bibliography entry — use nocite + strip pandoc div wrappers
        printf '%s\n' "---" "nocite: \"@${KEY}\"" "---" "" \
            | pandoc --citeproc --bibliography="$BIB" --csl="$CSL" -t markdown \
            | sed '/^:::*/d' \
            | sed '/^$/d'
        ;;
    inline)
        # Inline: "Author (Year)"
        printf '%s\n' "---" "bibliography: ${BIB}" "csl: ${CSL}" "---" "" "@${KEY}" \
            | pandoc --citeproc -t plain \
            | head -1
        ;;
    parens)
        # Parenthetical: "(Author, Year)"
        printf '%s\n' "---" "bibliography: ${BIB}" "csl: ${CSL}" "---" "" "[@${KEY}]" \
            | pandoc --citeproc -t plain \
            | head -1
        ;;
esac
